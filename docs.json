{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "palm",
  "name": "Vantage Wealth",
  "colors": {
    "primary": "#10B981",
    "light": "#34D399",
    "dark": "#059669"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#F1F5F9",
      "dark": "#0A0B0E"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/rmurarishetti/vantage"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/quickstart"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "groups": [
          {
            "group": "Overview",
            "pages": ["introduction", "quickstart"]
          },
          {
            "group": "Setup",
            "pages": [
              "setup/supabase",
              "setup/backend",
              "setup/flutter",
              "setup/android-setup"
            ]
          }
        ]
      },
      {
        "tab": "Features",
        "groups": [
          {
            "group": "Expense Tracking",
            "pages": [
              "features/expense-tracking",
              "features/supported-banks"
            ]
          },
          {
            "group": "AI Advisor",
            "pages": [
              "features/ai-advisor",
              "features/ai-tools"
            ]
          },
          {
            "group": "Finance",
            "pages": [
              "features/portfolio",
              "features/net-worth",
              "features/transfers",
              "features/bill-splitting"
            ]
          },
          {
            "group": "Android",
            "pages": ["features/widgets"]
          }
        ]
      },
      {
        "tab": "AI System",
        "groups": [
          {
            "group": "Architecture",
            "pages": [
              "ai/architecture",
              "ai/rag-pipeline",
              "ai/adding-tools"
            ]
          }
        ]
      },
      {
        "tab": "Self-Hosting",
        "groups": [
          {
            "group": "Deployment",
            "pages": [
              "self-hosting/overview",
              "self-hosting/ec2-deployment",
              "self-hosting/docker"
            ]
          }
        ]
      },
      {
        "tab": "Legal",
        "groups": [
          {
            "group": "Licensing",
            "pages": ["legal/license", "legal/cla"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/rmurarishetti/vantage",
          "icon": "github"
        },
        {
          "anchor": "Issues",
          "href": "https://github.com/rmurarishetti/vantage/issues",
          "icon": "circle-exclamation"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/rmurarishetti/vantage"
    }
  },
  "contextual": {
    "options": ["copy", "view", "claude"]
  }
}
